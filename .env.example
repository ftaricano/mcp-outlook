# Microsoft Graph API Configuration
MICROSOFT_GRAPH_CLIENT_ID=your_client_id_here
MICROSOFT_GRAPH_CLIENT_SECRET=your_client_secret_here
MICROSOFT_GRAPH_TENANT_ID=your_tenant_id_here

# Target User Configuration (optional)
# Deixe vazio ou comente para usar todos os usuários/delegated access
# Coloque um email específico para acessar emails de um usuário específico
# TARGET_USER_EMAIL=usuario.especifico@suaempresa.com

# Optional: Debug logging
DEBUG=true