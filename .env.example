# ========================================
# MCP Email Server - Environment Variables
# ========================================

# -----------------------------------------
# Azure AD (REQUIRED)
# -----------------------------------------
# Get these values from Azure Portal → App Registrations.
# Authentication uses the OAuth2 client-credentials flow (MSAL).
MICROSOFT_GRAPH_CLIENT_ID=your_client_id_here
MICROSOFT_GRAPH_CLIENT_SECRET=your_client_secret_here
MICROSOFT_GRAPH_TENANT_ID=your_tenant_id_here

# -----------------------------------------
# Mailbox target (OPTIONAL, recommended for app-permission setups)
# -----------------------------------------
# When the app uses application permissions, Microsoft Graph does NOT
# infer a mailbox from the client credential. Set TARGET_USER_EMAIL to
# the mailbox the server should act on.
TARGET_USER_EMAIL=

# -----------------------------------------
# Logging
# -----------------------------------------
# LOG_LEVEL controls stdout logging. Values: debug | info | warn | error
LOG_LEVEL=info

# MCP_SERVER_NAME / MCP_SERVER_VERSION show up in MCP handshake + logs.
# Defaults applied by the runtime if unset.
# MCP_SERVER_NAME=mcp-email
# MCP_SERVER_VERSION=0.0.0

# NODE_ENV: development | production | test
NODE_ENV=production

# -----------------------------------------
# Filesystem allowlist (security-critical)
# -----------------------------------------
# DOWNLOAD_DIR — directory where the server is allowed to WRITE files
# (attachment downloads, exported emails, etc.). Everything outside this
# directory is rejected by pathGuard.
# Defaults to <cwd>/downloads if unset.
DOWNLOAD_DIR=

# MCP_EMAIL_UPLOAD_DIRS — colon-separated list of directories the server
# is allowed to READ from when encoding a local file as an email
# attachment (send_email_with_file, encode_file_for_attachment, etc.).
# If unset, reads fall back to DOWNLOAD_DIR.
#
# Example:
#   MCP_EMAIL_UPLOAD_DIRS=/Users/me/Documents:/Users/me/Work/outgoing
#
# Any path outside this allowlist — including symlinks that resolve
# outside it and files in secret-bearing directories (.ssh, .aws,
# .gnupg, .env files, *.pem/*.key, etc.) — is rejected.
MCP_EMAIL_UPLOAD_DIRS=

# ========================================
# Azure AD permissions required
# ========================================
# Application Permissions (client-credentials flow):
#   - Mail.ReadWrite      (REQUIRED)
#   - Mail.Send           (REQUIRED)
#   - User.Read.All       (optional; enables list_users)
#   - Files.ReadWrite.All (optional)
#
# After configuring, click "Grant admin consent" in Azure Portal.

# ========================================
# Setup
# ========================================
# 1. cp .env.example .env
# 2. Fill in Azure AD credentials + TARGET_USER_EMAIL.
# 3. Set DOWNLOAD_DIR and MCP_EMAIL_UPLOAD_DIRS to the directories the
#    server is allowed to touch.
# 4. npm run build && npm start
