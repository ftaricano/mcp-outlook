# ========================================
# MCP Email Server - Environment Variables
# ========================================

# Azure AD Configuration (REQUIRED)
# Get these values from Azure Portal -> App Registrations
MICROSOFT_GRAPH_CLIENT_ID=your_client_id_here
MICROSOFT_GRAPH_CLIENT_SECRET=your_client_secret_here
MICROSOFT_GRAPH_TENANT_ID=your_tenant_id_here

# Multi-Tenant Support (OPTIONAL)
# Specify which user's mailbox to access
# Leave empty to use the service account's mailbox
# Examples:
#   - fernando.taricano@cpzseg.com.br (outlook-fernando)
#   - faturamento@cpzseg.com.br (outlook-faturamento)
TARGET_USER_EMAIL=

# Optional Settings
# Enable debug logging (default: false)
DEBUG=false

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# ========================================
# Azure AD Permissions Required
# ========================================
# Application Permissions (for Client Credentials flow):
#   - Mail.ReadWrite (REQUIRED)
#   - Mail.Send (REQUIRED)
#   - User.Read.All (optional - for list_users)
#   - Files.ReadWrite.All (optional - for advanced attachment operations)
#
# Delegated Permissions (for user-specific access):
#   - Mail.ReadWrite
#   - Mail.Send
#   - User.Read
#
# IMPORTANT: After configuring permissions, you MUST click
# "Grant admin consent" in the Azure Portal.
#
# ========================================
# Setup Instructions
# ========================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your Azure AD credentials
#
# 3. (Optional) Set TARGET_USER_EMAIL for multi-tenant setup
#
# 4. Build and run:
#    npm run build
#    npm start
#
# 5. Test connection:
#    node test-connection.js
#
# ========================================
# MCP Hub Configuration
# ========================================
# This server should be accessed through the MCP Hub.
# Configure in hub-config.json instead of using .env directly.
#
# Example hub-config.json:
# {
#   "servers": {
#     "outlook-fernando": {
#       "command": "node",
#       "args": ["/path/to/mcp-email/dist/index.js"],
#       "env": {
#         "MICROSOFT_GRAPH_CLIENT_ID": "your_id",
#         "MICROSOFT_GRAPH_CLIENT_SECRET": "your_secret",
#         "MICROSOFT_GRAPH_TENANT_ID": "your_tenant",
#         "TARGET_USER_EMAIL": "fernando.taricano@cpzseg.com.br"
#       }
#     },
#     "outlook-faturamento": {
#       "command": "node",
#       "args": ["/path/to/mcp-email/dist/index.js"],
#       "env": {
#         "MICROSOFT_GRAPH_CLIENT_ID": "your_id",
#         "MICROSOFT_GRAPH_CLIENT_SECRET": "your_secret",
#         "MICROSOFT_GRAPH_TENANT_ID": "your_tenant",
#         "TARGET_USER_EMAIL": "faturamento@cpzseg.com.br"
#       }
#     }
#   }
# }