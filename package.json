{
  "name": "mcp-outlook",
  "version": "2.1.0",
  "description": "MCP server for Microsoft Outlook and Exchange via Microsoft Graph",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "scripts/outlook.js",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "bin": {
    "outlook": "./scripts/outlook.js"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "jsonwebtoken": "^9.0.3"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.js\" \"*.md\" \"docs/**/*.md\" \".github/**/*.yml\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.js\" \"*.md\" \"docs/**/*.md\" \".github/**/*.yml\" \"*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke-test.js",
    "audit:prod": "npm audit --omit=dev",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "email",
    "exchange",
    "microsoft-graph",
    "model-context-protocol",
    "outlook",
    "typescript"
  ],
  "author": "Fernando Taricano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ftaricano/mcp-outlook.git"
  },
  "bugs": {
    "url": "https://github.com/ftaricano/mcp-outlook/issues"
  },
  "homepage": "https://github.com/ftaricano/mcp-outlook#readme",
  "dependencies": {
    "@azure/msal-node": "^5.2.4",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
