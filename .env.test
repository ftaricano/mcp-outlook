# Configurações Microsoft Graph (obrigatórias)
MICROSOFT_GRAPH_CLIENT_ID=your_client_id_here
MICROSOFT_GRAPH_CLIENT_SECRET=your_client_secret_here  
MICROSOFT_GRAPH_TENANT_ID=your_tenant_id_here

# Email específico do usuário (opcional - usa 'me' se não definido)
TARGET_USER_EMAIL=user@yourdomain.com

# Configurações HTTP Server (opcionais)
HTTP_PORT=3000
API_KEY=your_optional_api_key_for_authentication
CORS_ORIGIN=*

# Exemplos de configuração CORS mais restritivos:
# CORS_ORIGIN=https://yourapp.com,https://localhost:3000
# CORS_ORIGIN=https://*.yourdomain.com
EOF < /dev/null